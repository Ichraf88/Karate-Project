pipeline {
    agent any

    tools {
            jdk   'JAVA_HOME'     // ex: 'JDK21' dans mon cas JDK21.0.10
            maven 'MAVEN_HOME'    // ex: 'Maven3'
    }

    options {
        timestamps()
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Verify Java & Maven') {
            steps {
                bat 'java -version'
                bat 'mvn -version'
            }
        }

        stage('Run Karate Tests') {
            steps {
                bat 'mvn clean test'
            }
        }
    }

    post {
        always {
            junit allowEmptyResults: true, testResults: 'target/surefire-reports/*.xml'
            cucumber 'target/karate-reports/*.json'
            archiveArtifacts artifacts: 'target/karate-reports/**, target/surefire-reports/**', allowEmptyArchive: true
        }

        success {
            echo 'Build terminé avec succès. Rapports JUnit, Cucumber et Karate disponibles.'
        }

        failure {
            echo 'Build en échec. Vérifie les logs, les rapports JUnit et les rapports Karate.'
        }
    }
}