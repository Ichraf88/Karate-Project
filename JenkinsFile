pipeline {
    agent any

    tools {
        jdk 'JAVA_HOME'      // remplace par le nom exact configuré dans Jenkins si besoin
        maven 'MAVEN_HOME'   // remplace par le nom exact configuré dans Jenkins si besoin
    }

    options {
        timestamps()
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Verify Java & Maven') {
            steps {
                bat 'java -version'
                bat 'mvn -version'
            }
        }

        stage('Run Karate Tests') {
            steps {
                bat 'mvn clean test'
            }
        }
    }

    post {
        always {
            junit allowEmptyResults: true, testResults: 'target/surefire-reports/*.xml'

            archiveArtifacts artifacts: 'target/cucumber-html-reports/**, target/surefire-reports/**', allowEmptyArchive: true

            publishHTML(target: [
                reportDir: 'target/cucumber-html-reports',
                reportFiles: 'overview-features.html',
                reportName: 'Cucumber HTML Report',
                keepAll: true,
                alwaysLinkToLastBuild: true,
                allowMissing: true
            ])
        }

        success {
            echo 'Pipeline exécutée avec succès. Rapport HTML Cucumber publié.'
        }

        failure {
            echo 'Pipeline en échec. Vérifie les logs Maven, les résultats JUnit et le rapport HTML.'
        }
    }
}